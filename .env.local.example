# 复制为 .env.local 并填值。全部留空 = 本地 mock 模式（无需任何外部服务即可跑）。

# ── LLM：DeepSeek（不填 = mock，吐样张）─────────────
DEEPSEEK_API_KEY=
# MOCK_LLM=1            # 强制 mock（即使填了 KEY）

# ── 内容存储：Upstash for Redis（不填 = 进程内存，重启清空）──
# 在 Upstash / Vercel Marketplace 创建 Redis 后填；KV_REST_API_* 命名也兼容
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── 认证：Supabase（@supabase/ssr Cookie 会话；不填 = mock token "mock:<uid>"）──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=     # 新版可公开 key（旧项目可用 NEXT_PUBLIC_SUPABASE_ANON_KEY）

# ── 业务参数 ──────────────────────────────────────
GEN_DAILY_QUOTA=20                # 每用户每日新生成上限
# NEXT_TELEMETRY_DISABLED=1       # Windows 跨盘报 EXDEV 时启用
